# Database
DATABASE_URL=postgresql://provero:provero@localhost:5432/provero

# Stripe — core credentials
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe — price IDs (run `python billing/stripe.py --setup` to generate)
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id_here
STRIPE_PRO_PRICE_ID=price_your_pro_price_id_here

# Stripe — post-checkout redirect URLs
STRIPE_SUCCESS_URL=https://provero.io/billing/success
STRIPE_CANCEL_URL=https://provero.io/billing/cancel

# API
API_SECRET_KEY=your_api_secret_key_here

# App
APP_ENV=development
DEBUG=true
